def dfs(graph, start, goal):
frontier = [[start]]
explored = set()
while frontier:
path = frontier.pop()
node = path[-1]
print(f"Current Node: {node} | Path so far: {path}") # <-- Added
if node == goal:
return path
if node not in explored:
explored.add(node)
for neighbor in graph[node]:
frontier.append(path + [neighbor])
return None
graph = { 'A': ['B', 'C'], 'B': ['D', 'E'], 'C': ['F'], 'D': [], 'E': ['G'], 'F': [], 'G': [] }
result = dfs(graph, 'A', 'G')
print("\nFinal DFS Path:", result)
